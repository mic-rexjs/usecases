{
  "compilerOptions": {
    "strictNullChecks": true,
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "ESNext",
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strict": true,
    "resolveJsonModule": true,
    "strictPropertyInitialization": true,
    "lib": ["ESNext"],
    "paths": { "@/*": ["./src/*"] }
  },
  "exclude": ["./build"]
}
